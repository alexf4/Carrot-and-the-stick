# Carrot and the Stick — environment variables
# Copy to .env and fill in real values. Never commit .env.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Database (Supabase Postgres connection string) ---
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Rep matching ---
GOOGLE_CIVIC_API_KEY=your-google-civic-api-key

# --- Congress sync (ProPublica Congress API) ---
CONGRESS_API_KEY=your-propublica-api-key

# --- Rep seeding (Congress.gov API — separate from ProPublica) ---
CONGRESS_GOV_API_KEY=your-congress-gov-api-key
ADMIN_API_KEY=your-secret-admin-key
CONGRESS_SYNC_INTERVAL_MINUTES=60
